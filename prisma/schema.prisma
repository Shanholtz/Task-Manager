generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tasks {
  id        Int      @id @default(autoincrement())
  title     String
  status    Status   @default(TODO)
  user_id   String   @db.Uuid
  createdAt DateTime @default(now())
  due_date  DateTime @db.Date
  priority  Priority
}

enum Status {
  TODO
  IN_PROGRESS
  UNDER_REVIEW
  DONE
}

enum Priority {
  LOW
  NORMAL
  HIGH
}
